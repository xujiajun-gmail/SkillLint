# 微信公众号配置
# 复制此文件为 .env，并填入你的真实凭证

# 微信公众号 AppID（在公众号后台"开发-基本配置"中获取）
WECHAT_APPID=your_app_id_here

# 微信公众号 AppSecret（在公众号后台"开发-基本配置"中获取）
WECHAT_SECRET=your_app_secret_here

# 注意事项：
# 1. 此文件包含敏感信息，请勿提交到 Git 仓库
# 2. 确保 .gitignore 中包含 .env
# 3. 仅支持已认证的公众号
# 4. AppSecret 重置后需要更新此配置

# 可选配置
# WECHAT_AUTHOR=你的笔名
# WECHAT_AUTO_PUBLISH=false  # 是否自动发布（仅认证号支持）